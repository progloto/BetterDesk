<%- include('layouts/main', {
    title: _('help_request.title'),
    pageStyles: ['help-requests'],
    pageScripts: ['help-requests'],
    currentPage: 'help-requests',
    breadcrumb: [{ label: _('help_request.title') }],
    body: `
        <div class="help-requests-page">
            <!-- Header -->
            <div class="page-header">
                <div class="page-title">
                    <h1>${_('help_request.title')}</h1>
                </div>
                <p class="page-subtitle">${_('help_request.subtitle') || 'Manage incoming help requests from desktop clients'}</p>
            </div>

            <!-- Stats -->
            <div class="hr-stats" id="hr-stats">
                <div class="stat-card stat-total">
                    <span class="stat-value" id="stat-total">0</span>
                    <span class="stat-label">${_('help_request.stats_total') || 'Total'}</span>
                </div>
                <div class="stat-card stat-pending">
                    <span class="stat-value" id="stat-pending">0</span>
                    <span class="stat-label">${_('help_request.pending')}</span>
                </div>
                <div class="stat-card stat-accepted">
                    <span class="stat-value" id="stat-accepted">0</span>
                    <span class="stat-label">${_('help_request.accepted')}</span>
                </div>
                <div class="stat-card stat-resolved">
                    <span class="stat-value" id="stat-resolved">0</span>
                    <span class="stat-label">${_('help_request.resolved')}</span>
                </div>
            </div>

            <!-- Filters -->
            <div class="page-filters">
                <div class="filter-buttons">
                    <button class="btn filter-btn active" data-status="">${_('help_request.filter_all') || 'All'}</button>
                    <button class="btn filter-btn" data-status="pending">${_('help_request.pending')}</button>
                    <button class="btn filter-btn" data-status="accepted">${_('help_request.accepted')}</button>
                    <button class="btn filter-btn" data-status="resolved">${_('help_request.resolved')}</button>
                </div>
            </div>

            <!-- Requests List -->
            <div class="hr-list" id="hr-list">
                <div class="empty-state" id="hr-empty">
                    <span class="material-icons">support_agent</span>
                    <p>${_('help_request.no_requests')}</p>
                </div>
            </div>
        </div>
    `
}) %>
